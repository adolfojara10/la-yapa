# ---------- Django ----------
DJANGO_SECRET_KEY=replace-me-with-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=config.settings.dev

# ---------- Database (PostGIS required: postgis://, not postgres://) ----------
DATABASE_URL=postgis://layapa:layapa@localhost:5433/layapa

# ---------- Encryption ----------
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=

# ---------- Redis / Celery ----------
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ---------- CORS ----------
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081

# ---------- Email (MailHog in dev) ----------
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=localhost
EMAIL_PORT=1025
EMAIL_USE_TLS=False
DEFAULT_FROM_EMAIL=hola@layapa.ec

# ---------- Auth flow ----------
# Frontend URL used in password-reset emails. In prod, e.g. https://app.layapa.ec
FRONTEND_URL=http://localhost:3000
MOBILE_DEEP_LINK_SCHEME=layapa
EMAIL_VERIFICATION_OTP_TTL_MINUTES=15
PASSWORD_RESET_TOKEN_TTL_MINUTES=30

# ---------- Social auth (server-side id_token verification) ----------
# Google: CSV of all OAuth Client IDs that are valid `aud` for id_tokens issued
# to this app (iOS + Android + Web client IDs). Created in Google Cloud Console.
# See AGENTS.md §4 "Provisioning social auth credentials".
GOOGLE_OAUTH_CLIENT_IDS=
# Apple: bundle ID used as `aud` in Apple identity tokens (matches app.json).
APPLE_BUNDLE_ID=ec.layapa.app
APPLE_TEAM_ID=

# ---------- Payments ----------
# When True, all provider HTTP is replaced by FakePaymentProvider — safe for
# tests + local dev without real credentials. See AGENTS.md §4
# "Provisioning payment providers".
USE_FAKE_PAYMENT_PROVIDER=False

# PayPhone (sandbox creds from dev.payphone.app — see AGENTS.md)
PAYPHONE_API_KEY=
PAYPHONE_SECRET=
PAYPHONE_WEBHOOK_SECRET=
PAYPHONE_BASE_URL=https://pay.payphonetodoesposible.com

# DeUna (sandbox creds from deuna.com developer portal)
DEUNA_PUBLIC_KEY=
DEUNA_SECRET_KEY=
DEUNA_WEBHOOK_SECRET=
DEUNA_BASE_URL=https://api.deuna.com/v1

# Webhook hardening
PAYMENT_WEBHOOK_REPLAY_WINDOW_SECONDS=600
# CSV of CIDRs; empty = allow any (dev / staging without IP info).
PAYMENT_WEBHOOK_IPS_PAYPHONE=
PAYMENT_WEBHOOK_IPS_DE_UNA=

# Bonus credit defaults
BUSINESS_CANCELLATION_BONUS_AMOUNT=1.00
BUSINESS_CANCELLATION_BONUS_TTL_DAYS=90

# ---------- Third-party (fill for full functionality) ----------
SENTRY_DSN=
MAPBOX_ACCESS_TOKEN=
CLOUDFLARE_R2_ACCESS_KEY=
CLOUDFLARE_R2_SECRET_KEY=
CLOUDFLARE_R2_BUCKET=
CLOUDFLARE_R2_ENDPOINT=
RESEND_API_KEY=
EXPO_ACCESS_TOKEN=
