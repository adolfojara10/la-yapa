# ---------- API ----------
# For Android emulator, use http://10.0.2.2:8000/api/v1 to reach host's localhost.
EXPO_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

# ---------- Social auth (Google) ----------
# Client IDs from Google Cloud Console (see AGENTS.md §4 "Provisioning social auth credentials").
# iOS / Android client IDs are used by expo-auth-session; web client ID is also valid for
# id_token `aud` on the server.
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# ---------- Mapbox ----------
EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN=

# ---------- Sentry ----------
EXPO_PUBLIC_SENTRY_DSN=

# ---------- PostHog ----------
EXPO_PUBLIC_POSTHOG_API_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://us.posthog.com
