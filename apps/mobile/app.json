{
  "expo": {
    "name": "La Yapa",
    "slug": "la-yapa",
    "scheme": "layapa",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "ec.layapa.app",
      "usesAppleSignIn": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FAF6F0"
      },
      "package": "ec.layapa.app"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-splash-screen",
      "expo-asset",
      "expo-secure-store",
      "expo-apple-authentication",
      [
        "@rnmapbox/maps",
        {
          "RNMapboxMapsDownloadToken": ""
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Usamos tu ubicación para mostrarte bolsas cerca de ti.",
          "locationWhenInUsePermission": "Usamos tu ubicación para mostrarte bolsas cerca de ti."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "La cámara se usa para escanear el código QR del pedido al confirmar el retiro."
        }
      ],
      "expo-notifications"
    ],
    "experiments": {
      "typedRoutes": false
    },
    "extra": {
      "apiBaseUrl": "http://localhost:8000/api/v1"
    }
  }
}
